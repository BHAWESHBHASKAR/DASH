# Rust build artifacts
/target/

# cargo-fuzz build artifacts (fuzz/ is its own workspace with its own Cargo.lock)
/fuzz/target/
/fuzz/Cargo.lock

# Local collaboration / planning artifacts (not part of product)
/.buddy/
buddy.md
progress.md
/skills/
/.planning/

# Local release/test artifacts
/dist/
/dist-hook-test/
/docs/benchmarks/history/runs/
/docs/benchmarks/history/concurrency/
/docs/benchmarks/scorecards/
/docs/execution/phases/

# Local helper scratch files
fix_structs.py

# Stray test markers
.bash_test_marker.txt

# Runtime local files
*.wal
*.wal.snapshot
*.log

# Env/editor/system
.env
.env.*
.DS_Store
.localized

# ---------------------------------------------------------------------------
# SDK build artifacts
# ---------------------------------------------------------------------------

# Python SDK (sdks/python/)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
sdks/python/dist/
sdks/python/build/
.venv/
venv/
.envrc

# Go SDK (sdks/go/)
# Go leaves no committed build artifacts (binaries are in $GOBIN).
# Vendored deps and build cache are out-of-tree by default.

# TypeScript SDK (sdks/typescript/)
sdks/typescript/node_modules/
sdks/typescript/dist/
sdks/typescript/coverage/
sdks/typescript/.tsbuild/
*.tsbuildinfo
.npm/
.yarn/

# WASM / R-extension artifacts (future use)
*.wasm
*.map
